EXCHANGE_EMAIL=adotts@mts.ru
# Or inject via scripts/run_sync.sh + Bitwarden (OPENCLAW_EXCHANGE_PASSWORD)
EXCHANGE_PASSWORD=
EXCHANGE_SERVER=e-mail.mts.ru
# Comma-separated Exchange folders to sync from the mailbox root.
EXCHANGE_SYNC_FOLDERS=Входящие,00 Пишут мне,01 Follow-up,04 Meeting,Согласования

# All cache timestamps: Europe/Moscow via ews-mcp/tzutil.py (store_time / display_*).
# Hermes agent context: timezone: Europe/Moscow in config.yaml.

# Batched cache sync (sync.py)
SYNC_BATCH_SIZE=50
SYNC_OVERLAP_MINUTES=5
SYNC_FIRST_SYNC_DAYS=2
SYNC_BODY_MAX=4000
